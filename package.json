{
  "name": "fitshop-front",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.7",
    "@mui/lab": "7.0.1-beta.25",
    "@mui/material": "^7.3.7",
    "@reduxjs/toolkit": "^1.8.1",
    "axios": "^0.27.2",
    "moment": "^2.29.4",
    "react": "^18.2.0",
    "react-dom": "^18.0.0",
    "react-redux": "^7.2.8",
    "react-router-dom": "^5.1.9",
    "react-scripts": "5.0.0",
    "redux-logger": "3.0.6",
    "styled-components": "5.3.5",
    "sweetalert2": "^11.4.23",
    "swiper": "^12.1.4",
    "typescript": "~4.9.5",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@craco/craco": "^7.1.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^27.5.2",
    "@types/node": "^17.0.45",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/react-router-dom": "^5.1.9",
    "@types/redux-logger": "^3.0.13",
    "@types/styled-components": "^5.1.36"
  },
  "scripts": {
    "start": "PORT=3000 DISABLE_ESLINT_PLUGIN=true TSC_COMPILE_ON_ERROR=true NODE_OPTIONS=--max-old-space-size=8192 craco start",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 craco build",
    "start:prod": "serve -s build -l 80",
    "test": "craco test",
    "eject": "react-scripts eject",
    "typecheck": "tsc --noEmit"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "jest": {
    "moduleNameMapper": {
      "^swiper/react$": "<rootDir>/src/__mocks__/swiperReactMock.js",
      "^swiper/modules$": "<rootDir>/src/__mocks__/swiperModulesMock.js",
      "^swiper/css(.*)$": "<rootDir>/src/__mocks__/styleMock.js"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
